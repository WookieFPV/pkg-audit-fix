{
  "name": "pkg-audit-fix",
  "version": "0.2.0",
  "description": "Audit and remediate dependency vulnerabilities across pnpm, npm, yarn, and bun projects.",
  "type": "module",
  "bin": {
    "pkg-audit-fix": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run test",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "package:check": "publint && npm pack --dry-run",
    "ci": "biome check . && tsc --noEmit && vitest run test && tsdown && publint"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "audit",
    "security",
    "dependencies",
    "pnpm",
    "npm",
    "yarn",
    "bun",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WookieFPV/pkg-audit-fix.git"
  },
  "dependencies": {
    "picospinner": "3.0.0",
    "package-manager-detector": "1.6.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "2.30.0",
    "@types/node": "25.5.0",
    "bun-types": "1.3.11",
    "lefthook": "2.1.4",
    "publint": "0.3.18",
    "tsdown": "0.21.7",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
